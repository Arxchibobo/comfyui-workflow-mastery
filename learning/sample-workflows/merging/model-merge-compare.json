{
  "_comment": "ComfyUI Model Merge + Test Workflow: Weighted Sum + Block Weighted + Add Difference",
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "sd_xl_base_1.0.safetensors" },
    "_meta": { "title": "Model A (SDXL Base)" }
  },
  "2": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "albedobaseXL_v21.safetensors" },
    "_meta": { "title": "Model B (AlbedoBase XL)" }
  },
  "10": {
    "class_type": "ModelMergeSimple",
    "inputs": {
      "model1": ["1", 0],
      "model2": ["2", 0],
      "ratio": 0.5
    },
    "_meta": { "title": "Simple Merge (50/50)" }
  },
  "11": {
    "class_type": "ModelMergeBlocks",
    "inputs": {
      "model1": ["1", 0],
      "model2": ["2", 0],
      "input": 0.3,
      "middle": 0.5,
      "out": 0.8
    },
    "_meta": { "title": "Block Merge (构图A + 风格B)" }
  },
  "20": {
    "class_type": "CLIPMergeSimple",
    "inputs": {
      "clip1": ["1", 1],

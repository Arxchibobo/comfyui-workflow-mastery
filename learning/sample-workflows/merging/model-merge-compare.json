    },
    "_meta": { "title": "CLIP Merge (50/50)" }
  },
  "30": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "a majestic phoenix rising from flames, golden feathers, dramatic lighting, cinematic composition, 8k ultra detailed",
      "clip": ["20", 0]
    },
    "_meta": { "title": "Positive Prompt" }
  },
  "31": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "blurry, low quality, deformed, ugly, text, watermark",
      "clip": ["20", 0]

    "_meta": { "title": "Negative Prompt" }
  },
  "40": {
    "class_type": "EmptyLatentImage",
    "inputs": { "width": 1024, "height": 1024, "batch_size": 1 },
    "_meta": { "title": "SDXL Resolution" }
  },
  "50": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["10", 0],
      "positive": ["30", 0],
      "negative": ["31", 0],
      "latent_image": ["40", 0],
      "seed": 42,
      "steps": 25,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    },
    "_meta": { "title": "KSampler (Simple Merge)" }
  },
  "51": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["11", 0],
      "positive": ["30", 0],
      "negative": ["31", 0],
      "latent_image": ["40", 0],
      "seed": 42,
      "steps": 25,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0

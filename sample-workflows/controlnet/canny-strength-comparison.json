  "_analysis_guide": {
    "观察维度": [
      "1. 边缘遵循度：生成图像的边缘是否与 Canny 图吻合",
      "2. 自然度：图像是否看起来自然，没有不自然的边缘强化",
      "3. 细节质量：纹理、光照、色彩是否丰富",
      "4. 伪影：是否出现颜色异常、纹理重复、边缘光晕",
      "5. 创意空间：模型在遵循结构的基础上，能否添加有趣的细节"
    ],
    "预期最优范围": "0.6-0.8 通常是 Canny ControlNet 的最佳平衡点"

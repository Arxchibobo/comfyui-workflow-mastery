  "notes": {
    "triple_control_strategy": {
      "IP-Adapter": "控制全局风格(油画感)，weight=0.65 适中，0-70% 时段生效",
      "Depth": "控制空间层次，strength=0.6 辅助角色，0-50% 只管构图",
      "Pose": "控制人物姿势，strength=0.8 较高优先级，0-80% 持续稳定",
      "分时策略": "三者在时间轴上部分重叠但主导阶段不同，减少冲突"
    },
    "injection_paths": {
      "IP-Adapter": "→ model (修改 U-Net attention 层)",
      "ControlNet": "→ conditioning (通过零卷积注入 U-Net encoder/middle)",
      "不同路径": "IP-Adapter 和 ControlNet 走不同的注入路径，天然兼容"
    },
    "tuning_tips": [
      "如果风格太弱: 提高 IP-Adapter weight 到 0.8",
      "如果姿势不准: 提高 Pose strength 到 1.0",
      "如果构图混乱: 延长 Depth end_percent 到 0.7",
      "如果图像过度约束(呆板): 降低所有 ControlNet strength",
      "先单独测试每个控制，确认各自效果后再组合"
    ]
  }
}

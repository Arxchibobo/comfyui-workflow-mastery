{
  "metadata": {
    "title": "SDXL Micro-Conditioning Comparison Experiment",
    "description": "Systematically compare the effects of SDXL's three micro-conditioning parameters: c_size, c_crop, and c_ar. Same seed/prompt, only conditioning varies.",
    "author": "comfyui-learning",
    "created": "2026-03-21",
    "tags": ["sdxl", "conditioning", "experiment", "comparison"]
  },
  "experiment_design": {
    "objective": "Understand how size/crop/target conditioning affects SDXL output",
    "control_variables": {
      "seed": 42,
      "prompt": "a detailed oil painting of a medieval castle on a hilltop, dramatic clouds, golden hour lighting",
      "negative": "blurry, low quality",
      "steps": 30,
      "cfg": 6.5,
      "sampler": "dpmpp_2m_sde",
      "scheduler": "karras",
      "resolution": "1024x1024"
    },
    "experiments": [
      {
        "name": "A1_size_1024",
        "description": "Baseline: c_size=(1024,1024)",
        "c_size": [1024, 1024],
        "c_crop": [0, 0],
        "c_ar": [1024, 1024],
        "expected": "Clean, high-resolution output (default behavior)"
      },
      {
        "name": "A2_size_512",
        "description": "Low size conditioning: c_size=(512,512)",
        "c_size": [512, 512],
        "c_crop": [0, 0],
        "c_ar": [1024, 1024],
        "expected": "Slightly lower apparent detail, model thinks it's enhancing a 512px image"
      },
      {
        "name": "A3_size_256",
        "description": "Very low size conditioning: c_size=(256,256)",
        "c_size": [256, 256],
        "c_crop": [0, 0],
        "c_ar": [1024, 1024],
        "expected": "Noticeable quality degradation, softer/blurrier style"
      },
      {
        "name": "A4_size_2048",
        "description": "Upscaled size conditioning: c_size=(2048,2048)",
        "c_size": [2048, 2048],
        "c_crop": [0, 0],
        "c_ar": [1024, 1024],
        "expected": "Potentially sharper details, model thinks source is very high-res"
      },
      {
        "name": "B1_crop_0_0",
        "description": "Baseline: no crop offset",
        "c_size": [1024, 1024],
        "c_crop": [0, 0],
        "c_ar": [1024, 1024],
        "expected": "Centered, complete composition"
      },
      {
        "name": "B2_crop_256_0",
        "description": "Vertical crop offset: crop_h=256",
        "c_size": [1024, 1024],
        "c_crop": [0, 256],
        "c_ar": [1024, 1024],
        "expected": "Composition shifted up, as if cropped from a taller image"
      },
      {
        "name": "B3_crop_0_256",
        "description": "Horizontal crop offset: crop_w=256",
        "c_size": [1024, 1024],
        "c_crop": [256, 0],
        "c_ar": [1024, 1024],
        "expected": "Composition shifted left"
      },
      {
        "name": "C1_target_match",
        "description": "Baseline: target matches actual resolution",
        "c_size": [1024, 1024],
        "c_crop": [0, 0],
        "c_ar": [1024, 1024],
        "expected": "Standard 1:1 composition"
      },
      {
        "name": "C2_target_wide",
        "description": "Widescreen target: c_ar=(1024,576)",
        "c_size": [1024, 1024],
        "c_crop": [0, 0],
        "c_ar": [1024, 576],
        "expected": "Even though actual output is 1024x1024, composition may feel wider/more panoramic"
      },
      {
        "name": "C3_target_tall",
        "description": "Portrait target: c_ar=(576,1024)",
        "c_size": [1024, 1024],
        "c_crop": [0, 0],
        "c_ar": [576, 1024],
        "expected": "Composition may feel taller/more vertical despite being square output"
      }
    ]
  },
  "last_node_id": 30,
